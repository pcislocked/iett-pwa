{
  "name": "iett-pwa",
  "private": true,
  "version": "0.3.27",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
